<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="10dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="0dp"
  >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="14dp"
        android:paddingVertical="12dp">

        <!-- STATO CONNESSO -->
        <TextView
            android:id="@+id/dispositivo_connesso_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dispositivo Connesso"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@android:color/holo_green_dark"
            android:visibility="gone"

            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- ICONA -->
        <ImageView
            android:id="@+id/icona_bluetooth"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/b_home"
            app:tint="@android:color/black"

            app:layout_constraintTop_toBottomOf="@id/dispositivo_connesso_txt"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="8dp"/>

        <!-- NOME DEVICE -->
        <TextView
            android:id="@+id/nomeDispositivo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Nome Dispositivo"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginStart="10dp"

            app:layout_constraintStart_toEndOf="@id/icona_bluetooth"
            app:layout_constraintTop_toTopOf="@id/icona_bluetooth"
            app:layout_constraintBottom_toBottomOf="@id/icona_bluetooth"
            app:layout_constraintEnd_toStartOf="@id/disconnettibtn"/>

        <!-- BOTTONE DISCONNETTI -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/disconnettibtn"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Disconnetti"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:visibility="gone"

            app:cornerRadius="18dp"
            app:strokeWidth="1dp"
            app:strokeColor="#FF5252"
            android:textColor="#FF5252"
            android:backgroundTint="@android:color/transparent"

            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/icona_bluetooth"
            app:layout_constraintBottom_toBottomOf="@id/icona_bluetooth"/>

        <ImageView
            android:id="@+id/iconaChevron"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/ic_media_play"
            android:alpha="0.25"
            android:visibility="visible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>








