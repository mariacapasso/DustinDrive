<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_background">

    <!-- HEADER -->
    <TextView
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingTop="40dp"
        android:background="@drawable/black_border"
        android:text="Scan Bluetooth"
        android:textSize="22sp"
        android:textColor="@color/black"
        android:fontFamily="@font/roboto_bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- CENTRO INFO -->
    <pl.droidsonroids.gif.GifImageView
        android:id="@+id/gifImageView"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/bluetooth"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/textView5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ricerca Dispositivi"
        android:textSize="22sp"
        android:fontFamily="@font/roboto_bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toBottomOf="@id/gifImageView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/textView6"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginHorizontal="24dp"
        android:text="Assicurati che il dispositivo DUSTIN sia acceso"
        android:textSize="13sp"
        android:gravity="center"
        android:textColor="@color/gray1"
        app:layout_constraintTop_toBottomOf="@id/textView5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- LISTA DISPOSITIVI -->
    <TextView
        android:id="@+id/discoveredTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dispositivi Trovati"
        android:textSize="14sp"
        android:fontFamily="@font/roboto_bold"
        android:textColor="@color/black"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toBottomOf="@id/textView6"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/badgeCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="11sp"
        android:textColor="@color/white"
        android:fontFamily="@font/roboto_bold"
        android:gravity="center"
        android:paddingHorizontal="7dp"
        android:paddingVertical="2dp"
        android:layout_marginStart="8dp"
        app:layout_constraintStart_toEndOf="@id/discoveredTitle"
        app:layout_constraintTop_toTopOf="@id/discoveredTitle"
        app:layout_constraintBottom_toBottomOf="@id/discoveredTitle" />


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardList"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="@color/white"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/discoveredTitle"
        app:layout_constraintBottom_toTopOf="@id/ricerca_btn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
      >


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/listaDispositivi"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingVertical="6dp"
            tools:itemCount="4"
            tools:listitem="@layout/device_item"/>

        <!-- Empty state: visibile quando la lista è vuota -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="visible">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/b_home"
                android:alpha="0.18" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Nessun dispositivo trovato"
                android:textSize="14sp"
                android:fontFamily="@font/roboto_bold"
                android:textColor="@color/gray1" />


        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- BOTTONE SEMPRE IN BASSO -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/ricerca_btn"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="14dp"
        android:text="Ricerca dispositivi"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="@color/white"
        android:fontFamily="@font/roboto_bold"
        app:backgroundTint="@color/gray1"
        app:cornerRadius="16dp"
        app:icon="@drawable/find_device"
        app:iconTint="@color/white"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>